    {
      "id": "reservoir_schema",
      "type": "text",
      "x": -643.3333333333335,
      "y": 343,
      "width": 420,
      "height": 184,
      "text": "id               BIGSERIAL     PRIMARY KEY\ncorrelation_id   VARCHAR       (from NS1 prefetch)\nexternal_token   VARCHAR       (from NS2 tokenize)\nstatus           AVAILABLE | RESERVED | USED\n                 \u21b3 AVAILABLE  \u2014 ready to assign\n                 \u21b3 RESERVED   \u2014 picked by Card API\n                 \u21b3 USED \u2705    \u2014 card created, written\nreserved_by      VARCHAR       (ECS task ID)\n                 \u21b3 cleanup: RESERVED > 5min \u2192 AVAILABLE\nreserved_at      TIMESTAMP\ncreated_at       TIMESTAMP\n\nINDEX ON (id) WHERE status = 'AVAILABLE'",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#5f3dc4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "version": 86,
      "versionNonce": 1922626354,
      "index": "bWL",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1774981954065,
      "link": null,
      "locked": false,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "id               BIGSERIAL     PRIMARY KEY\ncorrelation_id   VARCHAR       (from NS1 prefetch)\nexternal_token   VARCHAR       (from NS2 tokenize)\nstatus           AVAILABLE | RESERVED | USED\n                 \u21b3 AVAILABLE  \u2014 ready to assign\n                 \u21b3 RESERVED   \u2014 picked by Card API\n                 \u21b3 USED \u2705    \u2014 card created, written\nreserved_by      VARCHAR       (ECS task ID)\n                 \u21b3 cleanup: RESERVED > 5min \u2192 AVAILABLE\nreserved_at      TIMESTAMP\ncreated_at       TIMESTAMP\n\nINDEX ON (id) WHERE status = 'AVAILABLE'",
      "autoResize": true,
      "lineHeight": 1.1794871794871795
    },
