    {
      "id": "cardapi_steps",
      "type": "text",
      "x": -105.4920998141663,
      "y": 380.42775418126087,
      "width": 215.5918731689453,
      "height": 185,
      "text": "\u2460 Validate + Reserve token\n   (SELECT FOR UPDATE\n    SKIP LOCKED) \u2192 RESERVED\n\n\u2461 Call TSYS (card request)\n\u2462 \u2190 card# (PAN) returned\n\n\u2463 prefetchMap\n   (card#, corrId)\n   \u2192 1 TOME call only\n\n\u2464 Store card_ref_id\n   in Card Table\n\u2465 Mark reservoir \u2192 USED \u2705",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "version": 156,
      "versionNonce": 1624558130,
      "index": "bWT",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1774981954065,
      "link": null,
      "locked": false,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2460 Validate + Reserve token\n   (SELECT FOR UPDATE\n    SKIP LOCKED) \u2192 RESERVED\n\n\u2461 Call TSYS (card request)\n\u2462 \u2190 card# (PAN) returned\n\n\u2463 prefetchMap\n   (card#, corrId)\n   \u2192 1 TOME call only\n\n\u2464 Store card_ref_id\n   in Card Table\n\u2465 Mark reservoir \u2192 USED \u2705",
      "autoResize": true,
      "lineHeight": 0.9076923076923078
    },
