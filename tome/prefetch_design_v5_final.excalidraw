    {
      "id": "cleanup_text",
      "type": "text",
      "x": -989.5501825900096,
      "y": 357.1211070535553,
      "width": 240,
      "height": 170,
      "text": "@Scheduled every 5min\n\n\u2460 DELETE stale RESERVED\n   where reserved_at < NOW()-5min\n   (dead \u2014 corrId used in TOME,\n    cannot be reused)\n\n\u2461 DELETE old USED rows\n   where created_at < NOW()-Xdays\n   (TTL archival, keeps table lean)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e67700",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "strokeStyle": "solid",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "@Scheduled every 5min\n\n\u2460 DELETE stale RESERVED\n   where reserved_at < NOW()-5min\n   (dead \u2014 corrId used in TOME,\n    cannot be reused)\n\n\u2461 DELETE old USED rows\n   where created_at < NOW()-Xdays\n   (TTL archival, keeps table lean)",
      "autoResize": true,
      "lineHeight": 1.3,
