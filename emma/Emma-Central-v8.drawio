        <mxCell id="Hj2W5uPPpjN2sFp9lBE7-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666;" value="How Nexus detects duplication, dependency and discarded decisions across squads — before damage is done" vertex="1">
