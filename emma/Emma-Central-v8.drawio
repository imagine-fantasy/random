        <mxCell id="Hj2W5uPPpjN2sFp9lBE7-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=2;" value="Emma — Squads 2-4, 6-11, 13-30&#xa;All feeding tagged knowledge objects to Nexus" vertex="1">
