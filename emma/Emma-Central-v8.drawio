        <mxCell id="Hj2W5uPPpjN2sFp9lBE7-7" parent="1" style="shape=datastore;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" value="D4: Cross-Squad Knowledge Store  ·  Qdrant  ·  All 30 Emmas feed in  ·  problem · constraint · discarded · outcome · squad · sprint · date · confidence" vertex="1">
